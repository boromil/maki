#!/usr/bin/env python3
"""
Anthropic OAuth dynamic provider for maki.

Install: cp scripts/providers/anthropic-oauth ~/.maki/providers/anthropic-oauth && chmod +x ~/.maki/providers/anthropic-oauth
Usage:   maki auth login anthropic-oauth
         maki -m anthropic-oauth/claude-sonnet-4-20250514

Requires Python 3.8+ with no external dependencies.
Stores tokens at ~/.maki/auth/anthropic.json
"""

import json
import os
import sys
import time
import urllib.request
import urllib.parse
import hashlib
import base64
import secrets

CLIENT_ID = "9d1c250a-e61b-44d9-88ed-5944d1962f5e"
AUTHORIZE_URL = "https://claude.ai/oauth/authorize"
TOKEN_URL = "https://platform.claude.com/v1/oauth/token"
REDIRECT_URI = "https://platform.claude.com/oauth/code/callback"
SCOPES = "org:create_api_key user:profile user:inference user:sessions:claude_code user:mcp_servers user:file_upload"
USER_AGENT = "claude-code/2.1.80"
BETA_ADVANCED_TOOL_USE = "advanced-tool-use-2025-11-20"
SYSTEM_PREFIX = "You are Claude Code, Anthropic's official CLI for Claude."
REFRESH_BUFFER_SECS = 60

TOKEN_FILE = os.path.expanduser("~/.maki/auth/anthropic.json")


def load_tokens():
    try:
        with open(TOKEN_FILE) as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        return None


def save_tokens(tokens):
    os.makedirs(os.path.dirname(TOKEN_FILE), exist_ok=True)
    tmp = TOKEN_FILE + ".tmp"
    with open(tmp, "w") as f:
        json.dump(tokens, f, indent=2)
    os.chmod(tmp, 0o600)
    os.replace(tmp, TOKEN_FILE)


def now_ms():
    return int(time.time() * 1000)


def is_expired(tokens):
    return now_ms() + REFRESH_BUFFER_SECS * 1000 >= tokens["expires"]


def post_json(url, data):
    body = json.dumps(data).encode()
    req = urllib.request.Request(
        url,
        data=body,
        headers={"Content-Type": "application/json", "User-Agent": "axios/6.7.1"},
        method="POST",
    )
    with urllib.request.urlopen(req, timeout=30) as resp:
        return json.loads(resp.read())


def build_resolved(tokens):
    return {
        "base_url": "https://api.anthropic.com/v1/messages?beta=true",
        "headers": {
            "authorization": f"Bearer {tokens['access']}",
            "anthropic-beta": f"oauth-2025-04-20,interleaved-thinking-2025-05-14,{BETA_ADVANCED_TOOL_USE}",
            "user-agent": USER_AGENT,
        },
    }


def do_refresh(tokens):
    resp = post_json(TOKEN_URL, {
        "grant_type": "refresh_token",
        "refresh_token": tokens["refresh"],
        "client_id": CLIENT_ID,
    })
    refresh = resp.get("refresh_token") or tokens["refresh"]
    new_tokens = {
        "access": resp["access_token"],
        "refresh": refresh,
        "expires": now_ms() + resp["expires_in"] * 1000,
    }
    save_tokens(new_tokens)
    return new_tokens


def cmd_info():
    print(json.dumps({
        "display_name": "Anthropic OAuth",
        "base": "anthropic",
        "system_prefix": SYSTEM_PREFIX,
        "has_auth": True,
    }))


def cmd_resolve():
    tokens = load_tokens()
    if not tokens:
        print("not authenticated, run: maki auth login anthropic-oauth", file=sys.stderr)
        sys.exit(1)
    if is_expired(tokens):
        try:
            tokens = do_refresh(tokens)
        except Exception as e:
            print(f"token refresh failed: {e}", file=sys.stderr)
            sys.exit(1)
    print(json.dumps(build_resolved(tokens)))


def cmd_refresh():
    tokens = load_tokens()
    if not tokens:
        print("no tokens to refresh", file=sys.stderr)
        sys.exit(1)
    try:
        tokens = do_refresh(tokens)
    except Exception as e:
        print(f"token refresh failed: {e}", file=sys.stderr)
        sys.exit(1)
    print(json.dumps(build_resolved(tokens)))


def cmd_login():
    verifier = base64.urlsafe_b64encode(secrets.token_bytes(32)).rstrip(b"=").decode()
    challenge = base64.urlsafe_b64encode(
        hashlib.sha256(verifier.encode()).digest()
    ).rstrip(b"=").decode()

    params = urllib.parse.urlencode({
        "code": "true",
        "client_id": CLIENT_ID,
        "response_type": "code",
        "redirect_uri": REDIRECT_URI,
        "scope": SCOPES,
        "code_challenge": challenge,
        "code_challenge_method": "S256",
        "state": challenge,
    }, quote_via=urllib.parse.quote)
    url = f"{AUTHORIZE_URL}?{params}"

    print(f"Open this URL in your browser:\n\n{url}\n")
    code = input("Paste the authorization code: ").strip()
    if not code:
        print("no authorization code provided", file=sys.stderr)
        sys.exit(1)

    parts = code.split("#", 1)
    auth_code = parts[0]
    state = parts[1] if len(parts) > 1 else ""

    resp = post_json(TOKEN_URL, {
        "code": auth_code,
        "state": state,
        "grant_type": "authorization_code",
        "client_id": CLIENT_ID,
        "redirect_uri": REDIRECT_URI,
        "code_verifier": verifier,
    })

    refresh = resp.get("refresh_token", "")
    if not refresh:
        print("missing refresh_token in response", file=sys.stderr)
        sys.exit(1)

    tokens = {
        "access": resp["access_token"],
        "refresh": refresh,
        "expires": now_ms() + resp["expires_in"] * 1000,
    }
    save_tokens(tokens)
    print("Authenticated successfully.")


def cmd_logout():
    try:
        os.remove(TOKEN_FILE)
        print("Logged out.")
    except FileNotFoundError:
        print("Not currently logged in.")


def main():
    if len(sys.argv) < 2:
        print(f"usage: {sys.argv[0]} <info|resolve|refresh|login|logout>", file=sys.stderr)
        sys.exit(1)

    cmd = sys.argv[1]
    commands = {
        "info": cmd_info,
        "resolve": cmd_resolve,
        "refresh": cmd_refresh,
        "login": cmd_login,
        "logout": cmd_logout,
    }

    fn = commands.get(cmd)
    if not fn:
        print(f"unknown command: {cmd}", file=sys.stderr)
        sys.exit(1)
    fn()


if __name__ == "__main__":
    main()
